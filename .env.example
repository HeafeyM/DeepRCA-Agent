# ============================================
# DeepRCA-Agent Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.

# --- Application ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- LLM ---
# OpenAI-compatible API endpoint
LLM_API_BASE=http://localhost:11434/v1
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=30

# --- Redis (standard Redis, NOT Squirrel) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Kafka (standard Kafka, NOT Mafka) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FEEDBACK_TOPIC=deeprca-feedback
KAFKA_FEEDBACK_DELAY_MS=1800000

# --- Analysis ---
ANALYSIS_TIMEOUT=60
TOOL_CALL_TIMEOUT=10
MAX_CONCURRENT_TASKS=10
SATISFACTION_PUSH_DELAY=1800

# --- Mock Environment ---
MOCK_ENV_ENABLED=true
MOCK_K8S_API=http://localhost:8001
MOCK_MONITOR_API=http://localhost:8002
MOCK_LOG_API=http://localhost:8003
MOCK_CHANGE_API=http://localhost:8004
